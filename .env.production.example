# ===========================================
# 河美果里果气 - 生产环境配置
# ===========================================
# 注意：这些是示例值，请替换为您的真实配置

# 微信小程序配置（可选，用于真实微信支付）
# WX_APP_ID=wx_your_appid
# WX_APP_SECRET=your_app_secret
# WX_MCH_ID=your_merchant_id
# WX_MCH_KEY=your_api_key

# Supabase 数据库配置（如果使用）
# SUPABASE_URL=https://your-project.supabase.co
# SUPABASE_ANON_KEY=your_anon_key
# SUPABASE_SERVICE_KEY=your_service_key

# 对象存储配置（如果使用）
# TOS_ENDPOINT=https://tos.your-region.bytepluses.com
# TOS_REGION=your-region
# TOS_ACCESS_KEY=your_access_key
# TOS_SECRET_KEY=your_secret_key
# TOS_BUCKET=your_bucket_name
